# Sensitive
.credentials.json

# Session/runtime state (regenerated)
session-env/
shell-snapshots/
sessions/
ide/
paste-cache/
file-history/
tasks/
telemetry/
history.jsonl
stats-cache.json
mcp-needs-auth-cache.json
projects/

# Plugin cache (managed by Claude Code, has embedded git repos)
plugins/cache/
plugins/install-counts-cache.json

# Settings backups
backups/
*.backup-*
settings.json.bak-*
settings.json.bad-*

# Runtime cleanup marker
.last-cleanup

# Cache
cache/
plugins/marketplaces/
plugins/data/

# Hook runtime logs (operational data, regenerated)
hooks/.log/

# External skills (auto-installed by doctor.sh, managed upstream)
skills/grill-with-docs/

# Personal Claude Code config (user-specific tokens, env vars)
# Use settings.example.json as template; install.sh handles merge.
settings.json

# Machine-local state managed by Claude Code (regenerated; not source).
# Plugin manifests perpetually drift — enablement is captured in settings.example.json.
.last-update-result.json
.update.lock
plugins/installed_plugins.json
plugins/known_marketplaces.json
# Native plan-mode storage (transient; harness RPI plans live in docs/superpowers/plans/)
/plans/

# Ad-hoc diagnostic/debug scratch dirs at repo root (e.g. _diag/, _repro/) — not source
/_*/

# Playwright MCP scratch (console logs / traces) — regenerated by the plugin, not source
/.playwright-mcp/
