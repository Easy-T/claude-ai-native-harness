{
  "$schema": "https://claude.ai/schemas/claude-code-settings",
  "_description": "Minimal settings for Claude AI-Native Harness. Copy to settings.json and customize. See README.md for plugin installation steps.",
  "env": {
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "60"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "TodoWrite",
      "TodoRead",
      "NotebookRead",
      "NotebookEdit"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline.sh",
    "padding": 0
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-orchestrator.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/stable-claude-md.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-rpi-cycle.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-secret-scan.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/surface-constitution.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-rpi-bash.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-secret-scan.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-compact-watch.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/session-start-audit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/verify-loop-watch.sh"
          }
        ]
      }
    ]
  }
}
