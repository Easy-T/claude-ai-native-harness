{
  "_comment_env": "Add your environment variables here (API tokens, model overrides, etc). For ccs proxy users, set ANTHROPIC_AUTH_TOKEN/ANTHROPIC_BASE_URL accordingly.",
  "env": {
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "TodoWrite",
      "TodoRead",
      "NotebookRead",
      "NotebookEdit"
    ],
    "defaultMode": "default"
  },
  "model": "opus",
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "superpowers-dev": {
      "source": {
        "source": "git",
        "url": "https://github.com/obra/superpowers.git"
      }
    }
  },
  "effortLevel": "max",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-orchestrator.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/stable-claude-md.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-rpi-cycle.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-compact-watch.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/session-start-audit.sh"
          }
        ]
      }
    ]
  }
}
